PORT=3000
NODE_ENV=development
TRUST_PROXY=1

# Public domain accepted without MX lookup.
BASE_DOMAIN=thvuinin.my.id

# Custom domains are valid only when their MX points here.
REQUIRED_MX_HOST=mx.thvuinin.my.id

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=d0535500cb173f97
REDIS_URL=redis://:d0535500cb173f97@127.0.0.1:6379

# Haraka SMTP receiver for local/dev. Use 25 in production service config if needed.
HARAKA_SMTP_HOST=0.0.0.0
HARAKA_SMTP_PORT=2525
HARAKA_SMTP_NODES=0
HARAKA_HEALTH_HOST=127.0.0.1

# Storage
EMAIL_STORAGE_DIR=./emails
EMAIL_SPOOL_DIR=./spool/emails
EMAIL_TTL_SECONDS=86400
INBOX_MAX_MESSAGES=20
INBOX_DAILY_LIMIT=50
EMAIL_QUEUE_STREAM=email_queue
EMAIL_QUEUE_GROUP=email_processors
EMAIL_QUEUE_BATCH_SIZE=10
EMAIL_QUEUE_MAXLEN=100000
DOMAIN_MX_CACHE_TTL_SECONDS=300

# API limits
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120

# Admin API. Set a strong value in production and send it as X-Admin-Token.
ADMIN_TOKEN=change-me-admin-token

# Optional OTP detection AI fallback. Set a real key only in .env / deployment secrets.
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OTP_AI_ENABLED=true
OTP_TEMPLATE_CACHE_TTL_SECONDS=2592000
OTP_AI_MAX_BODY_CHARS=3000
OTP_AI_DAILY_LIMIT=500

# WebSocket
WS_ENABLED=true

# Optional Cloudflare Tunnel for Express API/WebSocket only.
# Redis stays local and Haraka SMTP still needs public MX/port 25.
CLOUDFLARE_TUNNEL_ENABLED=false
CLOUDFLARE_TUNNEL_MODE=quick
CLOUDFLARE_TUNNEL_URL=http://127.0.0.1:3000
# CLOUDFLARE_TUNNEL_TOKEN=
# CLOUDFLARE_TUNNEL_CONFIG=./cloudflared/config.yml
# CLOUDFLARE_TUNNEL_NAME=tmail-api
