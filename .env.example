PORT=3000
NODE_ENV=development

# Public domain accepted without MX lookup.
BASE_DOMAIN=thvuinin.my.id

# Custom domains are valid only when their MX points here.
REQUIRED_MX_HOST=mx.thvuinin.my.id

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Haraka SMTP receiver for local/dev. Use 25 in production service config if needed.
HARAKA_SMTP_HOST=0.0.0.0
HARAKA_SMTP_PORT=2525
HARAKA_SMTP_NODES=0

# Storage
EMAIL_STORAGE_DIR=./emails
EMAIL_TTL_SECONDS=86400
INBOX_MAX_MESSAGES=20
INBOX_DAILY_LIMIT=50
DOMAIN_MX_CACHE_TTL_SECONDS=300

# API limits
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120

# Admin API. Set a strong value in production and send it as X-Admin-Token.
ADMIN_TOKEN=change-me-admin-token

# WebSocket
WS_ENABLED=true
